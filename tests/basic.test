# basic.test -- pdfiumtcl
#
# tcltest-Suite. Aufruf ueber tests/all.tcl (make test).

package require tcltest 2.5
namespace import ::tcltest::*

package require pdfiumtcl

set here [file dirname [file normalize [info script]]]
set pdf  [file join $here fixtures sample.pdf]

testConstraint havePdf [file exists $pdf]

test pdfiumtcl-1.1 {Paket ist geladen und meldet seine Version} -body {
    package provide pdfiumtcl
} -result 0.5.3

test pdfiumtcl-1.2 {Kommandos liegen in ::pdfium} -body {
    expr {[llength [info commands ::pdfium::open]] == 1}
} -result 1

test pdfiumtcl-1.3 {und NICHT in ::pdfium::pdfium -- der Namespace-Fallstrick} -body {
    llength [info commands ::pdfium::pdfium::*]
} -result 0

test pdfiumtcl-1.4 {Laden zieht kein Tk herein} -body {
    info exists ::tk_version
} -result 0

test pdfiumtcl-2.1 {open/pagecount/close} -constraints havePdf -body {
    set doc [pdfium::open $::pdf]
    set n [pdfium::pagecount $doc]
    pdfium::close $doc
    expr {$n >= 1}
} -result 1

test pdfiumtcl-2.2 {gettext liefert Text} -constraints havePdf -body {
    set doc [pdfium::open $::pdf]
    set t [pdfium::gettext $doc 0]
    pdfium::close $doc
    expr {[string length $t] > 0}
} -result 1

test pdfiumtcl-2.3 {open auf eine Nicht-PDF-Datei schlaegt sauber fehl} -body {
    catch {pdfium::open [info script]} e
    expr {[string length $e] > 0}
} -result 1

test pdfiumtcl-3.1 {addimagebitmap ohne Tk: Fehler, kein Absturz} -body {
    # 0.5.1 starb hier mit SIGSEGV -- Tk_FindPhoto ueber einen NULL-tkStubsPtr.
    catch {pdfium::addimagebitmap 0 0 nichtda 0 0 10 10} e
    expr {[string length $e] > 0}
} -result 1

cleanupTests
